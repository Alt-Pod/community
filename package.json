{
  "name": "community",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @community/web dev",
    "build": "yarn workspace @community/web build",
    "start": "yarn workspace @community/web start",
    "lint": "yarn workspace @community/web lint",
    "setup": "bash scripts/setup.sh",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:prod": "env $(cat .env.prod | xargs) node scripts/migrate.js",
    "inngest:dev": "npx inngest-cli@latest dev"
  },
  "repository": "https://github.com/Alt-Pod/community.git",
  "author": "Michael Dornic <michael@m-work.co>",
  "license": "MIT"
}
